{
  "name": "vaultmind",
  "version": "0.2.0",
  "private": true,
  "description": "VaultMind - private knowledge center with secure vault and AI retrieval",
  "main": "src/main.js",
  "scripts": {
    "start": "env -u ELECTRON_RUN_AS_NODE electron .",
    "dev": "NODE_ENV=development electron .",
    "build:ui": "cd ui && npm run build",
    "build": "npm run build:ui && npm run start",
    "test": "node scripts/test-core.js",
    "test:vector": "node scripts/test-vector.js"
  },
  "devDependencies": {
    "electron": "^33.4.11"
  },
  "dependencies": {
    "@xenova/transformers": "^2.17.2",
    "mammoth": "^1.12.0",
    "pdf-parse": "^2.4.5",
    "sql.js": "^1.14.1",
    "xlsx": "^0.18.5"
  }
}
